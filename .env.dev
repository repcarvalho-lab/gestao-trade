# ============================================================
# TraderOS — Ambiente DEV
# ============================================================

# Banco de dados (acessado de dentro do container)
DATABASE_URL="postgresql://traderos:traderos_dev_pass@postgres-dev:5432/traderos_dev"

# Para rodar o backend localmente (fora do Docker), use esta URL:
# DATABASE_URL="postgresql://traderos:traderos_dev_pass@localhost:5433/traderos_dev"

# JWT
JWT_SECRET="traderos-jwt-secret-dev-CHANGE-IN-PRODUCTION"
JWT_REFRESH_SECRET="traderos-refresh-secret-dev-CHANGE-IN-PRODUCTION"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Servidor
PORT=4000
NODE_ENV=development

# CORS
CORS_ORIGIN="http://localhost:3000"

# Frontend (usado pelo Vite)
VITE_API_URL="http://localhost:4000/api"
